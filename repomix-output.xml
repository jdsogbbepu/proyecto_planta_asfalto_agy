    --color-ink-secondary: #9aa0a9;
    --color-ink-tertiary: #5c6370;
    --color-ink-muted: #3d434d;

    --color-bitumen: #1a1d21;
    --color-steel: #2a3038;
    --color-steel-light: #3a424d;

    --color-accent: #f27b00;
    --color-accent-dim: rgba(242, 123, 0, 0.15);
    --color-accent-glow: rgba(242, 123, 0, 0.4);

    --color-status-active: #22c55e;
    --color-status-warning: #f59e0b;
    --color-status-danger: #ef4444;
    --color-status-info: #3b82f6;

    --color-border: rgba(255, 255, 255, 0.06);
    --color-border-emphasis: rgba(255, 255, 255, 0.1);
    --color-border-strong: rgba(255, 255, 255, 0.15);
}

@tailwind base;
@tailwind components;
@tailwind utilities;

body {
    background-color: var(--color-background);
    color: var(--color-ink-primary);
    font-family: 'Fira Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.control-panel {
    background: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: 8px;
}

.control-panel-raised {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 8px;
}

.indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-steel);
}

.indicator-active {
    background: var(--color-status-active);
    box-shadow: 0 0 8px var(--color-status-active), 0 0 16px rgba(34, 197, 94, 0.3);
    animation: pulse-glow 2s ease-in-out infinite;
}

.indicator-warning {
    background: var(--color-status-warning);
    box-shadow: 0 0 8px var(--color-status-warning);
}

.indicator-danger {
    background: var(--color-status-danger);
    box-shadow: 0 0 8px var(--color-status-danger);
}

@keyframes pulse-glow {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
}

.data-readout {
    font-family: 'Fira Code', monospace;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
}

.control-bar {
    height: 3px;
    background: var(--color-steel);
    border-radius: 2px;
    overflow: hidden;
}

.control-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 600ms cubic-bezier(0.16, 1, 0.3, 1);
}

.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-family: 'Fira Code', monospace;
}

.status-badge-active {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #4ade80;
}

.status-badge-warning {
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: #fbbf24;
}

.status-badge-danger {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #f87171;
}

.section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-tertiary);
