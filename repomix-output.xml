```css
/* Mobile: Hidden menu */
.nav-menu {
  display: none;
  flex-direction: column;
}

.menu-toggle {
  display: block;
}

.nav-menu.open {
  display: flex;
}

/* Desktop: Always visible */
@media (min-width: 768px) {
  .menu-toggle {
    display: none;
