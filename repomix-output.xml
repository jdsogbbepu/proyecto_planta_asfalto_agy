    flex: 1;
    height: 1px;
    background: var(--color-border);
}

.scrollbar-control::-webkit-scrollbar {
    width: 4px;
    height: 4px;
}

.scrollbar-control::-webkit-scrollbar-track {
    background: transparent;
}

.scrollbar-control::-webkit-scrollbar-thumb {
    background: var(--color-steel);
